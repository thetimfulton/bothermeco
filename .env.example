# BotherMe.co — Environment Variables
# Copy this file to .env.local and fill in the values.

# Twilio SMS integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PostgreSQL database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/bothermeco"

# Secret for authenticating cron job requests
CRON_SECRET=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://botherme.co
